{
  "name": "@beztack/payments",
  "version": "0.0.1",
  "description": "Provider-agnostic payment abstraction for Beztack",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "better-auth": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "better-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.1.8",
    "better-auth": "^1.0.0",
    "react": "^19.0.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.60"
  }
}
